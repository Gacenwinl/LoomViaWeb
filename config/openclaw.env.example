# 嘉豪 · OpenClaw Gateway 环境变量
# 复制为项目根目录 .env

# --- Vault ---
VAULT_PATH=/home/deploy/obsidian-vault

# --- LLM (SiliconFlow) ---
SILICONFLOW_API_KEY=sk-your-key-here
OPENCLAW_MODEL=deepseek-ai/DeepSeek-V3.2
OPENCLAW_REASONING=false
OPENCLAW_MAX_TOKENS=8192
OPENCLAW_TEMPERATURE=0.3

# --- Gateway ---
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_AGENT_NAME=jiahao
OPENCLAW_CONFIG_PATH=/config/.openclaw

# --- 行为开关 ---
MORNING_PRINT=true
STARTUP_FRICTION_PRINT=true
EVENING_AUTOSYNC=true

# --- 芯烨云 ---
XPRINTER_USER=your-user
XPRINTER_UKEY=your-ukey
XPRINTER_SN=your-device-sn

# --- Autosync (Gitee) ---
GITEE_REPO=https://gitee.com/your-org/obsidian-vault.git
GITEE_BRANCH=main
AUTOSYNC_INTERVAL_MIN=15

# --- 时区 ---
TZ=Asia/Shanghai
